<!DOCTYPE html>
<html>
  <head>
    <title>ToyApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container">
        <%= link_to "Toy App", root_path, class: "navbar-brand fw-bold" %>

        <div class="navbar-nav ms-auto">
          <%= link_to "Home", root_path, class: "nav-link text-white" %>
          <%= link_to "Contact", contact_path, class: "nav-link text-white" %>
          <%= link_to "Users", users_path, class: "nav-link text-white" %>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-warning"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
