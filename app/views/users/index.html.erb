<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="section-title mb-0">Users</h1>
  <%= link_to "New User", new_user_path, class: "btn btn-success" %>
</div>

<div class="card page-card">
  <div class="card-body">
    <% if @users.any? %>
      <div class="list-group">
        <% @users.each do |user| %>
          <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
            <div>
              <h5 class="mb-1"><%= user.name.presence || "No Name Yet" %></h5>
              <small class="text-muted"><%= user.email.presence || "No Email Yet" %></small>
            </div>

            <div class="mt-2 mt-md-0">
              <%= link_to "Show", user_path(user), class: "btn btn-sm btn-primary me-1" %>
              <%= link_to "Edit", edit_user_path(user), class: "btn btn-sm btn-warning me-1" %>
              <%= link_to "Boost", boost_user_path(user), data: { turbo_method: :patch }, class: "btn btn-sm btn-info me-1" %>
              <%= link_to "Delete", user_path(user), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mb-0">No users found yet.</p>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to "Back Home", root_path, class: "btn btn-outline-secondary" %>
</div>
